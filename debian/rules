#!/usr/bin/make -f

export SETUPTOOLS_SCM_PRETEND_VERSION=1.0.0

%:
	dh $@ --with python3

override_dh_auto_build:
	true

override_dh_auto_install:
	# Compiler les traductions
	for lang in fr en es de it pt ru ja zh_CN ar; do \
		msgfmt po/$$lang.po -o po/$$lang.mo; \
	done
	
	# Installer les fichiers de traduction
	mkdir -p debian/linux-hello/usr/share/locale/fr/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/en/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/es/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/de/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/it/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/pt/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/ru/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/ja/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/zh_CN/LC_MESSAGES
	mkdir -p debian/linux-hello/usr/share/locale/ar/LC_MESSAGES
	cp po/fr.mo debian/linux-hello/usr/share/locale/fr/LC_MESSAGES/linux-hello.mo
	cp po/en.mo debian/linux-hello/usr/share/locale/en/LC_MESSAGES/linux-hello.mo
	cp po/es.mo debian/linux-hello/usr/share/locale/es/LC_MESSAGES/linux-hello.mo
	cp po/de.mo debian/linux-hello/usr/share/locale/de/LC_MESSAGES/linux-hello.mo
	cp po/it.mo debian/linux-hello/usr/share/locale/it/LC_MESSAGES/linux-hello.mo
	cp po/pt.mo debian/linux-hello/usr/share/locale/pt/LC_MESSAGES/linux-hello.mo
	cp po/ru.mo debian/linux-hello/usr/share/locale/ru/LC_MESSAGES/linux-hello.mo
	cp po/ja.mo debian/linux-hello/usr/share/locale/ja/LC_MESSAGES/linux-hello.mo
	cp po/zh_CN.mo debian/linux-hello/usr/share/locale/zh_CN/LC_MESSAGES/linux-hello.mo
	cp po/ar.mo debian/linux-hello/usr/share/locale/ar/LC_MESSAGES/linux-hello.mo

	# Générer le wheel
	python3 -m pip wheel . --no-deps -w /tmp/linux-hello-build
	
	# Copier le wheel dans le répertoire du paquet
	mkdir -p debian/linux-hello/usr/share/linux-hello
	cp /tmp/linux-hello-build/linux_hello-*.whl debian/linux-hello/usr/share/linux-hello/
	
	# Installer la CLI et les scripts dans /usr/bin
	pip install . \
	    --root=$(CURDIR)/debian/linux-hello \
	    --prefix=/usr \
	    --no-deps \
		--ignore-installed \
	    --no-warn-script-location

	# Déplacer les scripts installés dans /usr/local/bin vers /usr/bin
	if [ -d debian/linux-hello/usr/local/bin ]; then \
	    mkdir -p debian/linux-hello/usr/bin; \
	    mv debian/linux-hello/usr/local/bin/* debian/linux-hello/usr/bin/; \
	    rm -rf debian/linux-hello/usr/local; \
	fi
	
	# Installer les pages man multilingues depuis debian/man/
	for lang in en fr de es it pt ru ja zh_CN ar; do \
		mkdir -p debian/linux-hello/usr/share/man/$${lang}/man1 debian/linux-hello/usr/share/man/$${lang}/man8; \
		[ -f debian/man/$${lang}/linux-hello.1 ] && cp debian/man/$${lang}/linux-hello.1 debian/linux-hello/usr/share/man/$${lang}/man1/ || true; \
		[ -f debian/man/$${lang}/linux-hello-daemon.8 ] && cp debian/man/$${lang}/linux-hello-daemon.8 debian/linux-hello/usr/share/man/$${lang}/man8/ || true; \
		[ -f debian/man/$${lang}/pam_linux_hello.8 ] && cp debian/man/$${lang}/pam_linux_hello.8 debian/linux-hello/usr/share/man/$${lang}/man8/ || true; \
	done
