#!/bin/bash
set -e

VENV="/opt/linux-hello/venv"
PYTHON="/usr/bin/python3"

echo "[linux-hello] Configuration du paquet…"

# 1. Créer les dossiers de données
mkdir -p /var/lib/linux-hello/faces
chmod 755 /var/lib/linux-hello
chmod 700 /var/lib/linux-hello/faces

# 2. Créer ou réparer le venv
echo "[linux-hello] Vérification du venv…"
/usr/lib/linux-hello/repair_venv.sh || true

# 3. Installer onnxruntime si absent
if ! "$VENV/bin/python3" -c "import onnxruntime" 2>/dev/null; then
    echo "[linux-hello] Installation de onnxruntime via pip…"
    "$VENV/bin/pip" install onnxruntime
fi

# 4. Modifier le shebang du daemon pour utiliser le venv
sed -i '1c #!/opt/linux-hello/venv/bin/python3' /usr/bin/linux-hello-daemon
chmod +x /usr/bin/linux-hello-daemon

# 5. Modifier le shebang de la CLI pour utiliser le venv
sed -i '1c #!/opt/linux-hello/venv/bin/python3' /usr/bin/hello
chmod +x /usr/bin/hello

# 6. Activer le service systemd si disponible
if command -v systemctl >/dev/null 2>&1; then
    echo "[linux-hello] Activation du service systemd…"
    systemctl daemon-reload || true
    systemctl enable --now linux-hello.service || true
else
    echo "[linux-hello] systemd non disponible (WSL2 ?), service non activé."
fi

# 7. Installer le module PAM
echo "[linux-hello] Installation du module PAM…"
chmod 755 /usr/lib/linux-hello/pam_linux_hello.py
chmod 644 /etc/pam.d/linux-hello

# 8. Lancer la configuration de la caméra si terminal interactif
if [ -t 1 ]; then
    echo "[linux-hello] Configuration initiale : sélection de la caméra…"
    /usr/bin/hello select-camera || true
else
    echo "[linux-hello] Mode non interactif : configuration de la caméra ignorée."
fi

echo ""
echo "[linux-hello] Pour activer l'authentification faciale dans PAM :"
echo ""
echo "Ajoutez la ligne suivante dans le fichier PAM du service souhaité :"
echo "    auth    sufficient    pam_exec.so quiet stdout /usr/lib/linux-hello/pam_linux_hello.py"
echo ""
echo "Exemples :"
echo "  sudo :      /etc/pam.d/sudo"
echo "  login TTY : /etc/pam.d/login"
echo "  GDM :       /etc/pam.d/gdm-password"
echo ""
echo "Linux‑Hello n'est pas activé automatiquement afin de respecter les"
echo "bonnes pratiques Debian concernant la configuration PAM."
echo ""

echo "[linux-hello] Installation terminée."