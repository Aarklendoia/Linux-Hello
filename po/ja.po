msgid "No face detected"
msgstr "顔が検出されませんでした"

msgid "✅ Embedding saved for %s"
msgstr "✅ %s の埋め込みを保存しました"

msgid "No embedding registered"
msgstr "埋め込みが登録されていません"

msgid "Similarity: %.3f"
msgstr "類似性: %.3f"

msgid "✅ Recognized"
msgstr "✅ 認識されました"

msgid "❌ Not recognized"
msgstr "❌ 認識されませんでした"

msgid "✅ Deleted: %s"
msgstr "✅ 削除: %s"

msgid "User not found"
msgstr "ユーザーが見つかりません"

msgid "OK"
msgstr "OK"

msgid "FAIL"
msgstr "エラー"

msgid "Venv missing"
msgstr "Venv がありません"

msgid "python3 missing from venv"
msgstr "venv に python3 がありません"

msgid "InsightFace not importable"
msgstr "InsightFace がインポート可能ではありません"

msgid "Daemon not active"
msgstr "デーモンがアクティブではありません"

msgid "Socket missing"
msgstr "ソケットがありません"

msgid "File exists but is not a socket"
msgstr "ファイルは存在しますが、ソケットではありません"

msgid "Camera inaccessible"
msgstr "カメラにアクセスできません"

msgid "Faces directory missing"
msgstr "顔ディレクトリがありません"

msgid "No registered faces"
msgstr "登録済みの顔がありません"

msgid "=== Linux Hello Doctor ==="
msgstr "=== Linux Hello Doctor ==="

msgid "Venv present"
msgstr "Venv が存在します"

msgid "Python in venv present"
msgstr "venv内のPythonが存在します"

msgid "InsightFace importable"
msgstr "InsightFaceはインポート可能です"

msgid "Daemon active"
msgstr "デーモンがアクティブです"

msgid "Unix socket present"
msgstr "Unixソケットが存在します"

msgid "Camera accessible"
msgstr "カメラにアクセス可能です"

msgid "Registered faces"
msgstr "登録済みの顔"

msgid "Testing camera %d…"
msgstr "カメラ %d をテスト中…"

msgid "Look at the LED or preview. Press Enter to continue."
msgstr "LED またはプレビューを見てください。Enter を押して続行します。"

msgid "Use camera %d? (y/N) "
msgstr "カメラ %d を使用しますか? (y/N) "

msgid "✅ Camera %d saved."
msgstr "✅ カメラ %d が保存されました。"

msgid "No camera detected."
msgstr "カメラが検出されません。"

msgid "No camera selected."
msgstr "カメラが選択されていません。"

msgid "❌ This command requires administrator privileges."
msgstr "❌ このコマンドには管理者権限が必要です。"

msgid "Please run: sudo hello select-camera"
msgstr "実行してください：sudo hello select-camera"

msgid "❌ This command cannot be run as root."
msgstr "❌ このコマンドは root として実行することはできません。"

msgid "Please run as a regular user."
msgstr "通常のユーザーとして実行してください。"

