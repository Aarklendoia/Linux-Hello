msgid "No face detected"
msgstr "Лицо не обнаружено"

msgid "No embedding registered"
msgstr "Встраивание не зарегистрировано"

msgid "Similarity: %.3f"
msgstr "Сходство: %.3f"

msgid "✅ Recognized"
msgstr "✅ Распознано"

msgid "❌ Not recognized"
msgstr "❌ Не распознано"

msgid "✅ Deleted: %s"
msgstr "✅ Удалено: %s"

msgid "User not found"
msgstr "Пользователь не найден"

msgid "OK"
msgstr "OK"

msgid "FAIL"
msgstr "ОШИБКА"

msgid "Venv missing"
msgstr "Venv отсутствует"

msgid "python3 missing from venv"
msgstr "python3 отсутствует в venv"

msgid "InsightFace not importable"
msgstr "InsightFace не импортируется"

msgid "Daemon not active"
msgstr "Демон неактивен"

msgid "Socket missing"
msgstr "Сокет отсутствует"

msgid "File exists but is not a socket"
msgstr "Файл существует, но это не сокет"

msgid "Camera inaccessible"
msgstr "Камера недоступна"

msgid "Faces directory missing"
msgstr "Каталог лиц отсутствует"

msgid "No registered faces"
msgstr "Нет зарегистрированных лиц"

msgid "=== Linux Hello Doctor ==="
msgstr "=== Linux Hello Doctor ==="

msgid "Venv present"
msgstr "Venv присутствует"

msgid "Python in venv present"
msgstr "Python в venv присутствует"

msgid "InsightFace importable"
msgstr "InsightFace импортируется"

msgid "Daemon active"
msgstr "Daemon активен"

msgid "Unix socket present"
msgstr "Unix сокет присутствует"

msgid "Camera accessible"
msgstr "Камера доступна"

msgid "Registered faces"
msgstr "Зарегистрированные лица"

msgid "Testing camera %d…"
msgstr "Тестирование камеры %d…"

msgid "Look at the LED or preview. Press Enter to continue."
msgstr "Посмотрите на светодиод или предпросмотр. Нажмите Enter для продолжения."

msgid "Use camera %d? (y/N) "
msgstr "Использовать камеру %d? (д/N) "

msgid "✅ Camera %d saved."
msgstr "✅ Камера %d сохранена."

msgid "No camera detected."
msgstr "Камера не обнаружена."

msgid "No camera selected."
msgstr "Камера не выбрана."

msgid "❌ This command requires administrator privileges."
msgstr "❌ Эта команда требует привилегий администратора."

msgid "Please run: sudo hello select-camera"
msgstr "Пожалуйста, выполните: sudo hello select-camera"

msgid "❌ This command cannot be run as root."
msgstr "❌ Эта команда не может быть выполнена от имени root."

msgid "Please run as a regular user."
msgstr "Пожалуйста, выполните от имени обычного пользователя."




msgid "Test recognition"
msgstr "Проверить распознавание"

msgid "List registered embeddings"
msgstr "Список зарегистрированных эмбеддингов"

msgid "Remove a user"
msgstr "Удалить пользователя"

msgid "Select camera for recognition."
msgstr "Выберите камеру для распознавания."

msgid "Register your face for authentication."
msgstr "Регистрируйте свое лицо для аутентификации."

msgid "Diagnose Linux Hello installation."
msgstr "Диагностировать инсталляцию Linux Hello."
