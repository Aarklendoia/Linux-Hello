msgid "No face detected"
msgstr "لم يتم اكتشاف أي وجه"

msgid "✅ Embedding saved for %s"
msgstr "✅ تم حفظ التضمين لـ %s"

msgid "No embedding registered"
msgstr "لا يوجد تضمين مسجل"

msgid "Similarity: %.3f"
msgstr "التشابه: %.3f"

msgid "✅ Recognized"
msgstr "✅ تم التعرف عليه"

msgid "❌ Not recognized"
msgstr "❌ لم يتم التعرف عليه"

msgid "✅ Deleted: %s"
msgstr "✅ تم الحذف: %s"

msgid "User not found"
msgstr "لم يتم العثور على المستخدم"

msgid "OK"
msgstr "OK"

msgid "FAIL"
msgstr "خطأ"

msgid "Venv missing"
msgstr "Venv غير موجود"

msgid "python3 missing from venv"
msgstr "python3 غير موجود في venv"

msgid "InsightFace not importable"
msgstr "لا يمكن استيراد InsightFace"

msgid "Daemon not active"
msgstr "الخادم غير نشط"

msgid "Socket missing"
msgstr "المقبس غير موجود"

msgid "File exists but is not a socket"
msgstr "الملف موجود لكنه ليس مقبسًا"

msgid "Camera inaccessible"
msgstr "الكاميرا غير متاحة"

msgid "Faces directory missing"
msgstr "دليل الوجوه مفقود"

msgid "No registered faces"
msgstr "لا توجد وجوه مسجلة"

msgid "=== Linux Hello Doctor ==="
msgstr "=== Linux Hello Doctor ==="

msgid "Venv present"
msgstr "Venv موجود"

msgid "Python in venv present"
msgstr "Python في venv موجود"

msgid "InsightFace importable"
msgstr "InsightFace قابل للاستيراد"

msgid "Daemon active"
msgstr "الخادم نشط"

msgid "Unix socket present"
msgstr "مقبس Unix موجود"

msgid "Camera accessible"
msgstr "الكاميرا متاحة"

msgid "Registered faces"
msgstr "الوجوه المسجلة"

msgid "Testing camera %d…"
msgstr "اختبار الكاميرا %d…"

msgid "Look at the LED or preview. Press Enter to continue."
msgstr "انظر إلى LED أو المعاينة. اضغط Enter للمتابعة."

msgid "Use camera %d? (y/N) "
msgstr "هل تستخدم الكاميرا %d؟ (y/N) "

msgid "✅ Camera %d saved."
msgstr "✅ تم حفظ الكاميرا %d."

msgid "No camera detected."
msgstr "لم يتم الكشف عن كاميرا."

msgid "No camera selected."
msgstr "لم يتم تحديد كاميرا."

msgid "❌ This command requires administrator privileges."
msgstr "❌ هذا الأمر يتطلب امتيازات المسؤول."

msgid "Please run: sudo hello select-camera"
msgstr "يرجى تشغيل: sudo hello select-camera"

msgid "❌ This command cannot be run as root."
msgstr "❌ لا يمكن تشغيل هذا الأمر كجذر."

msgid "Please run as a regular user."
msgstr "يرجى تشغيله كمستخدم عادي."

