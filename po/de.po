msgid "No face detected"
msgstr "Kein Gesicht erkannt"

msgid "No embedding registered"
msgstr "Keine Einbettung registriert"

msgid "Similarity: %.3f"
msgstr "Ähnlichkeit: %.3f"

msgid "✅ Recognized"
msgstr "✅ Erkannt"

msgid "❌ Not recognized"
msgstr "❌ Nicht erkannt"

msgid "✅ Deleted: %s"
msgstr "✅ Gelöscht: %s"

msgid "User not found"
msgstr "Benutzer nicht gefunden"

msgid "OK"
msgstr "OK"

msgid "FAIL"
msgstr "FEHLER"

msgid "Venv missing"
msgstr "Venv fehlt"

msgid "python3 missing from venv"
msgstr "python3 fehlt in venv"

msgid "InsightFace not importable"
msgstr "InsightFace nicht importierbar"

msgid "Daemon not active"
msgstr "Daemon nicht aktiv"

msgid "Socket missing"
msgstr "Socket fehlt"

msgid "File exists but is not a socket"
msgstr "Datei existiert, ist aber kein Socket"

msgid "Camera inaccessible"
msgstr "Kamera nicht erreichbar"

msgid "Faces directory missing"
msgstr "Gesichtsverzeichnis fehlt"

msgid "No registered faces"
msgstr "Keine registrierten Gesichter"

msgid "=== Linux Hello Doctor ==="
msgstr "=== Linux Hello Doctor ==="

msgid "Venv present"
msgstr "Venv vorhanden"

msgid "Python in venv present"
msgstr "Python in venv vorhanden"

msgid "InsightFace importable"
msgstr "InsightFace importierbar"

msgid "Daemon active"
msgstr "Daemon aktiv"

msgid "Unix socket present"
msgstr "Unix-Socket vorhanden"

msgid "Camera accessible"
msgstr "Kamera erreichbar"

msgid "Registered faces"
msgstr "Registrierte Gesichter"

msgid "Testing camera %d…"
msgstr "Kamera %d wird getestet…"

msgid "Look at the LED or preview. Press Enter to continue."
msgstr "Schauen Sie auf die LED oder Vorschau. Drücken Sie die Eingabetaste zum Fortfahren."

msgid "Use camera %d? (y/N) "
msgstr "Kamera %d verwenden? (j/N) "

msgid "✅ Camera %d saved."
msgstr "✅ Kamera %d gespeichert."

msgid "No camera detected."
msgstr "Keine Kamera erkannt."

msgid "No camera selected."
msgstr "Keine Kamera ausgewählt."

msgid "❌ This command requires administrator privileges."
msgstr "❌ Dieses Kommando erfordert Administratorrechte."

msgid "Please run: sudo hello select-camera"
msgstr "Bitte führen Sie aus: sudo hello select-camera"

msgid "❌ This command cannot be run as root."
msgstr "❌ Dieses Kommando kann nicht als root ausgeführt werden."

msgid "Please run as a regular user."
msgstr "Bitte führen Sie es als regulärer Benutzer aus."




msgid "Test recognition"
msgstr "Erkennung testen"

msgid "List registered embeddings"
msgstr "Registrierte Embeddings auflisten"

msgid "Remove a user"
msgstr "Benutzer entfernen"

msgid "Select camera for recognition."
msgstr "Wählen Sie eine Kamera für die Erkennung aus."

msgid "Register your face for authentication."
msgstr "Registrieren Sie Ihr Gesicht zur Authentifizierung."

msgid "Diagnose Linux Hello installation."
msgstr "Linux Hello-Installation diagnostizieren."
